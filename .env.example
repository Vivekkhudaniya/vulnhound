# ============================================
# VulnHound Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-...           # Primary: Claude Sonnet/Opus for reasoning
OPENAI_API_KEY=sk-...                  # For text-embedding-3-large embeddings

# === Blockchain RPCs (for Anvil forking) ===
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# === Block Explorer APIs (for verified source code) ===
ETHERSCAN_API_KEY=...
ARBISCAN_API_KEY=...
BASESCAN_API_KEY=...

# === Vector Database ===
# Local dev: ChromaDB (no key needed, uses ./data/chromadb)
VECTOR_DB_PROVIDER=chromadb
# Production: Pinecone
# VECTOR_DB_PROVIDER=pinecone
# PINECONE_API_KEY=...
# PINECONE_INDEX=vulnhound-exploits

# === Optional: Reranker ===
# COHERE_API_KEY=...

# === Agent Config ===
LLM_MODEL=claude-sonnet-4-20250514
LLM_MODEL_HEAVY=claude-opus-4-5-20250929    # for complex cross-contract analysis
LLM_MODEL_FAST=claude-haiku-4-5-20251001    # for pre-filtering, dedup
MAX_CONCURRENT_ANALYSES=5
FINDING_CONFIDENCE_THRESHOLD=0.7

# === Paths ===
KNOWLEDGE_BASE_DIR=./knowledge
CHROMADB_DIR=./data/chromadb
REPORTS_DIR=./reports
